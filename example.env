# PiSynapse Environment Configuration Template
# To use this: 
# 1. Rename this file from '.env.example' to '.env'
# 2. Fill in the values below with your own credentials

# --- AI Configuration ---
# The address of your local Ollama instance
OLLAMA_HOST=http://localhost:11434
# The specific model you want PiSynapse to use
MODEL=gemma4:e2b

# --- Nextcloud Configuration ---
# Your Nextcloud server address (e.g., https://cloud.example.com)
NEXTCLOUD_URL=
# Your Nextcloud username
NEXTCLOUD_USER=
# Use an "App Password" generated from your Nextcloud security settings
NEXTCLOUD_PASSWORD=

# --- Database Configuration ---
# Path to the local SQLite database file
DATABASE_URL=sqlite+aiosqlite:///assistant.db

# --- Gmail Integration ---
# Your full Gmail address
GMAIL_USER=your_email@gmail.com
# Use an "App Password" from Google Account settings (not your regular login password)
GMAIL_APP_PASSWORD=

# --- Personalization ---
# How you want the assistant to address you
ASSISTANT_USER=YourName
