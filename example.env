# ============================================================
# piSynapse — Environment Configuration
# Rename this file to .env before running the app.
# ============================================================

# --- Ollama / LLM ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e2b

# LLM generation settings
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_KEEP_ALIVE=24h
LLM_TIMEOUT=120
LLM_MAX_ITERATIONS=5

# --- Embedding ---
# Multilingual model, works for 50+ languages, ~470MB
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Memory ---
# Cosine similarity threshold for deduplication (0.0–1.0)
# Higher = stricter matching, fewer deduplication hits
MEMORY_SIMILARITY_THRESHOLD=0.68
# How many past messages to include in each request
HISTORY_LIMIT=12
# How many long-term memories to inject into each request
MEMORY_LIMIT=10
# How many aged-out messages to batch before generating/updating the
# rolling conversation summary (lower = more frequent summary LLM calls)
SUMMARY_BATCH_SIZE=10

# --- Database ---
DB_PATH=assistant.db

# --- Weather ---
# Default city used when the user doesn't specify one
DEFAULT_CITY=
# Timeout for weather API calls (in seconds)
WEATHER_TIMEOUT=10

# --- Nextcloud ---
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASSWORD=

# --- Gmail ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# --- Personalization ---
ASSISTANT_USER=
